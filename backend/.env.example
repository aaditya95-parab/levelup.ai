# Backend environment example
# Copy to .env and fill in with real values for local development

# Server
PORT=5000

# JWT secret (change for production)
JWT_SECRET=change-me-in-production

# Google AI (Gemini) API key and optional model
GOOGLE_AI_API_KEY=
# Optional: override default Gemini model (e.g. gemini-2.0-flash)
GOOGLE_AI_MODEL=

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/levelup

# Any other provider secrets (optional)
# OPENAI_API_KEY=
